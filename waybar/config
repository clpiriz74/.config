{
  "layer": "top",
  "position": "top",
  "modules-left": [
    "sway/workspaces",
    "custom/firefox",
    "custom/term",
    "custom/nvim",
    "custom/virtual"   
   ],
  "modules-center": ["clock"],
  "modules-right": [
    "custom/network",
    "custom/bluetooth", 
    "pulseaudio", 
    "custom/battery", 
    "custom/logout", 
    "tray"
   ],

  "clock": {
    "format": "{:%H:%M}",
    "tooltip-format": "{:%A, %d %B %Y}"
  },

  "pulseaudio": {
    "format": " {volume}%",
    "format-muted": "",
    "on-click": "pavucontrol" // asegúrate de tenerlo instalado
  },

  "custom/battery": {
    "exec": "~/.config/waybar/scripts/battery.sh",
    "interval": 10,
    "return-type": "json",
    "format": "{text}",
    "tooltip": true,
  },


  "custom/bluetooth": {
    "format": "{}",
    "return-type": "json",
    "tooltip": true,
    "tooltip-format": "Bluetooth",
    "on-click": "blueman-manager",
    "exec": "~/.config/waybar/scripts/bluetooth_status.sh",
    "interval": 10
  }, 

  "custom/logout": {
    "format": "",
    "tooltip": true,
    "tooltip-format": "Logout\nShutdown\nReboot",
    "on-click": "/home/elpa/.config/sway/powermenu.sh"
    // o para un menú: "on-click": "wlogout" (si lo tienes instalado)
  },

  "custom/firefox": {
    "format": "",  // Ícono de Firefox (usando Nerd Font)
    "tooltip": true,
    "tooltip-format": "Navegador",
    "on-click": "firefox",
    "on-click-right": "firefox --private-window"
  },

  "custom/term": {
    "format": "",  // Ícono de terminal (foot)
    "tooltip-format": "Terminal",
    "on-click": "foot"
  },

  "custom/nvim": {
    "format": "",  // Ícono de Neovim
    "tooltip-format": "Editor de Texto",
    "on-click": "foot nvim"
  },

  
  "custom/network": {
    "exec": "~/.config/waybar/scripts/network_status.sh",
    "interval": 10,
    "return-type": "json",
    "format": "{text}",
    "tooltip": true,
    "on-click": "foot nmtui"
  },
  
  "custom/virtual": {
    "format": " ",  
    "tooltip-format": "Virtual Machine Manager",
    "on-click": "virt-manager"
  },

}

